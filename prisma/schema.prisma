// Prisma schema for AurumIQ
// Defines the data model for the financial analysis platform.
// PostgreSQL is used for relational queries across portfolio holdings,
// analysis history, and user management.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Core user account for authentication and portfolio ownership.
/// bcryptjs handles password hashing at the application layer.
model User {
  id              String            @id @default(uuid())
  email           String            @unique
  hashedPassword  String
  name            String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  holdings        Holding[]
  analyses        Analysis[]
  priceAlerts     PriceAlert[]
  earningsAlerts  EarningsAlert[]
  schedules       Schedule[]
  analysisHistory AnalysisHistory[]

  @@map("users")
}

/// Token-based password reset flow (AUTH-04).
/// Tokens are single-use (usedAt tracks consumption) and expire after 1 hour.
/// Old unused tokens for the same email are cleaned up on each new request
/// to prevent token accumulation.
model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_reset_tokens")
}

/// User's portfolio holding. quantity supports fractional shares (up to 8 decimal places).
/// costBasis is nullable because users adding a holding may not know their entry price
/// (e.g., imported from a broker without cost basis data).
model Holding {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  ticker    String
  quantity  Decimal  @db.Decimal(20, 8)
  costBasis Decimal? @map("cost_basis") @db.Decimal(20, 8)
  addedAt   DateTime @default(now()) @map("added_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
  @@index([userId])
  @@map("holdings")
}

/// Cached raw API responses from financial data providers.
/// One row per (ticker, dataType) — upserted on refresh so the cache
/// stays bounded while history lives in source providers.
/// JSONB absorbs the volatile shape of Yahoo Finance responses
/// (fields appear/disappear, types vary across security types).
model RawData {
  id        String   @id @default(uuid())
  ticker    String
  dataType  String   @map("data_type")
  data      Json
  fetchedAt DateTime @default(now()) @map("fetched_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([ticker, dataType])
  @@index([ticker, dataType, fetchedAt])
  @@map("raw_data")
}

/// AI-generated analysis section for a (user, ticker, sectionType).
/// One latest row per tuple — the `@@unique([userId, ticker, sectionType])`
/// constraint enables upsert-on-refresh while older versions live in
/// AnalysisHistory (Phase 6).
/// `sources` snapshots the data passed to the prompt for traceability and
/// post-generation hallucination validation; `content` is the structured
/// JSON output the section component renders.
model Analysis {
  id          String         @id @default(uuid())
  userId      String
  ticker      String
  sectionType String         @map("section_type")
  status      String
  content     Json?
  sources     Json
  model       String
  errorMessage String?       @map("error_message")
  generatedAt DateTime       @default(now()) @map("generated_at")
  updatedAt   DateTime       @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker, sectionType])
  @@index([userId, ticker])
  @@map("analyses")
}

/// Price-cross alert. When the cached price moves past `threshold` in the
/// `direction` set by the user, the cron check fires an email and marks
/// the alert inactive (one-shot — users re-arm explicitly to avoid spam).
model PriceAlert {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  ticker      String
  direction   String
  threshold   Decimal   @db.Decimal(20, 8)
  triggeredAt DateTime? @map("triggered_at")
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
  @@index([ticker, active])
  @@map("price_alerts")
}

/// Earnings-date reminder. Fires once per upcoming earnings event, N
/// days before. `lastNotifiedDate` stores the date-only stamp of the
/// earnings event we already notified for, so a user who re-enters
/// the same N-day window after a new earnings date can be notified
/// again for the new event without double-firing the old one.
model EarningsAlert {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  ticker           String
  daysBefore       Int       @map("days_before")
  lastNotifiedDate DateTime? @map("last_notified_date") @db.Date
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
  @@index([ticker, active])
  @@map("earnings_alerts")
}

/// Daily scheduled AI regeneration for a (userId, ticker, sectionType).
/// `hour` + `minute` + `timezone` express the local-time slot the user
/// wants. The cron tick converts that to UTC at evaluation time.
/// `lastRunAt` is the wall-clock of the last fire (for diagnostics);
/// `lastRunDate` is the date-stamp of the last successful daily run
/// (gates re-firing if the cron tick runs twice the same day).
model Schedule {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  ticker      String
  sectionType String    @map("section_type")
  hour        Int
  minute      Int
  timezone    String
  active      Boolean   @default(true)
  lastRunAt   DateTime? @map("last_run_at")
  lastRunDate DateTime? @map("last_run_date") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker, sectionType])
  @@index([active])
  @@map("schedules")
}

/// Append-only log of every completed AI analysis. Drives the
/// AnalysisHistory view so users can compare today's Bull/Bear thesis
/// against last month's. The latest row per (user, ticker, section)
/// also lives on the `Analysis` table for read-path simplicity; this
/// table is for browsing past versions only.
model AnalysisHistory {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  ticker      String
  sectionType String   @map("section_type")
  content     Json
  sources     Json
  model       String
  generatedAt DateTime @default(now()) @map("generated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, ticker, sectionType, generatedAt(sort: Desc)])
  @@map("analysis_history")
}
